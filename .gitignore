# Obsidian app settings and state (user-specific, changes frequently)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/app.json
.obsidian/graph.json
.obsidian/bookmarks.json
.obsidian/hotkeys.json

# Obsidian plugin data (not tracked — reinstall from community plugins)
.obsidian/plugins/

# Copyrighted reference material (excluded from git — add your own copy locally)
_sources/processed/do-not-commit/

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.bak

# Python bytecode from _scripts helpers
__pycache__/

# Obsidian config for the nested campaigns/ vault (opened separately for graph view)
campaigns/.obsidian/
