filters:
  and:
    - file.inFolder("campaigns/lost-memories/npcs")
properties:
  status:
    displayName: Status
  faction:
    displayName: Faction
  location:
    displayName: Location
  role:
    displayName: Role
views:
  - type: table
    name: All NPCs
    groupBy:
      property: status
      direction: ASC
    order:
      - file.name
      - status
      - role
      - faction
      - location
