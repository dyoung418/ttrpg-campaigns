filters:
  and:
    - file.inFolder("campaigns/lost-memories/plot-hooks")
properties:
  status:
    displayName: Status
  priority:
    displayName: Priority
views:
  - type: table
    name: Active Hooks
    filters:
      not:
        - status == "resolved"
    groupBy:
      property: priority
      direction: DESC
    order:
      - file.name
      - status
      - priority
  - type: table
    name: All Hooks
    order:
      - file.name
      - status
      - priority
